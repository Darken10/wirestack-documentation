{
    "name": "wirestack/ui",
    "description": "Complete Design System for Laravel Livewire 4 — fully customizable, modular, and production-ready.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "livewire/livewire": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Wirestack\\Ui\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wirestack\\Ui\\WsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}